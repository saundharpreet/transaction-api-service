{
  "vault": {
    "url": "http://host.docker.internal:8200",
    "auth": {
      "method": "token",
      "token": "root-token"
    }
  },
  "secrets": [
    {
      "path": "secret/data/transaction-api-service",
      "key": "db.url",
      "to": "env",
      "name": "DATABASE_URL"
    },
    {
      "path": "secret/data/transaction-api-service",
      "key": "db.username",
      "to": "env",
      "name": "DATABASE_USERNAME"
    },
    {
      "path": "secret/data/transaction-api-service",
      "key": "mtls.crt",
      "to": "file",
      "destination": "/app/certs/mtls.crt"
    },
    {
      "path": "secret/data/transaction-api-service",
      "key": "mtls.key",
      "to": "file",
      "destination": "/app/certs/mtls.key"
    }
  ]
}